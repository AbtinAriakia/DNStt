[Unit]
Description=DNS Turbo Tunnel
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/dnstt-server \
    -udp :5300 \
    -privkey-file /etc/dnstt/server.key \
     t.example.com \
     127.0.0.1:22
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
